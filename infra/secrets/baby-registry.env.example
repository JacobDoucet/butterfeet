# Copy to baby-registry.env, fill in real values, then encrypt:
#   cd infra && sops --encrypt secrets/baby-registry.env > secrets/baby-registry.env.enc
#
# To decrypt locally:
#   cd infra && sops --decrypt secrets/baby-registry.env.enc > secrets/baby-registry.env

APP_ENV=production

# Must be a cryptographically random string, at least 32 characters.
# Generate one: openssl rand -base64 48
JWT_SECRET=

# Resend API key (added in Phase 2)
RESEND_API_KEY=

# Sender shown on outbound transactional email. The domain must be verified in
# Resend (see https://resend.com/docs/dashboard/domains/introduction).
MAIL_FROM=Stork Nest <hello@storknest.baby>

# MongoDB — use mongodb+srv:// for DO Managed Mongo, or mongodb://mongo:27017 for self-hosted
MONGO_URI=mongodb://mongo:27017
DB_NAME=baby_registry

PORT=8080
APP_BASE_URL=https://storknest.baby
CORS_ALLOWED_ORIGINS=https://storknest.baby
